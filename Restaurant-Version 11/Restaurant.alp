						<Parameter>
							<Name><![CDATA[onExit]]></Name>
							<Value Class="CodeValue">
								<Code><![CDATA[Agent waiter = agent.resourceUnitsOfPool(waiters).get(0);

double angle = agent.getRotation();
double offsetDistance = 9;
double offsetAngle = angle - Math.PI / 2;


double offsetX = agent.getX() + offsetDistance * Math.cos(offsetAngle);
double offsetY = agent.getY() + offsetDistance * Math.sin(offsetAngle);

waiter.setXY(offsetX, offsetY);

waiter.setRotation(angle + Math.PI / 2);]]></Code>
							</Value>
						</Parameter>
					</Parameters>
