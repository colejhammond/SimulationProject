							<Value Class="CodeValue">
								<Code><![CDATA[agent.myParty.entreeOrdersReady++;

if (agent.myParty.entreeOrdersReady == agent.myParty.entreeOrdersCreated) {
    FoodOrder delivery = add_foodOrders();
    delivery.myParty = agent.myParty;
    delivery.isEntree = true;
    delivery.isAppetizer = false;

    entreeDeliveryEnter.take(delivery);
}]]></Code>
