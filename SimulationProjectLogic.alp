						<Parameter>
							<Name><![CDATA[onExit]]></Name>
							<Value Class="CodeValue">
								<Code><![CDATA[// Reset tracking
agent.entreeOrdersCreated = agent.partySize;
agent.entreeOrdersReady = 0;
agent.allEntreesReady = false;

agent.appetizerOrdersCreated = 0;
agent.appetizerOrdersReady = 0;

agent.allFoodReady = false;

// Create one entree order per person
for (int i = 0; i < agent.partySize; i++) {
    FoodOrder entree = add_foodOrders();
    entree.myParty = agent;
    entree.isEntree = true;
    entree.isAppetizer = false;

    entreeKitchenEnter.take(entree);
}

// Optional appetizers
if (randomTrue(0.5)) {
    int numApps = uniform_discr(1, 2);

    agent.appetizerOrdersCreated = numApps;

    for (int i = 0; i < numApps; i++) {
        FoodOrder app = add_foodOrders();
        app.myParty = agent;
        app.isEntree = false;
        app.isAppetizer = true;

        appetizerKitchenEnter.take(app);
    }
}

//drink tasks
serviceTask drinkTask = add_serviceTasks();
drinkTask.myParty = agent;
drinkTaskEnter.take(drinkTask);]]></Code>
							</Value>
